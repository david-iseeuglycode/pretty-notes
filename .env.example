# SQL Server connection string
# Local dev (SQL Server auth):
DATABASE_URL="sqlserver://localhost:1433;database=pretty-notes;user=YOUR_USER;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=true"

# Shadow database for Prisma migrate dev
SHADOW_DATABASE_URL="sqlserver://localhost:1433;database=PrettyNotes_Shadow;user=YOUR_USER;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=true"

# JWT signing secret — use a long random string in production
JWT_SECRET="change-me"

# WebSocket CORS allowed origin — set to your domain in production, omit (or remove) to allow all origins (*)
CORS_ORIGIN="https://yourdomain.org"
